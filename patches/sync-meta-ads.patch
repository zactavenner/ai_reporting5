+// ── Ad Account Timezone Helper ──
+// Fetches and caches the ad account's timezone_name from Meta Graph API.
+// Cache lives in meta_ad_accounts table, refreshed every 24 hours.
+async function getAdAccountTimezone(
+  adAccountId: string,
+  accessToken: string,
+  supabase: any,
+  clientId: string
+): Promise<string> {
+  // Check cache first
+  const { data: cached } = await supabase
+    .from("meta_ad_accounts")
+    .select("timezone_name, last_seen_at")
+    .eq("ad_account_id", adAccountId)
+    .maybeSingle();
+
+  if (cached) {
+    const cacheAge = Date.now() - new Date(cached.last_seen_at).getTime();
+    const twentyFourHours = 24 * 60 * 60 * 1000;
+    if (cacheAge < twentyFourHours) {
+      console.log(`Using cached timezone for ${adAccountId}: ${cached.timezone_name}`);
+      return cached.timezone_name;
+    }
+  }
+
+  // Fetch from Meta Graph API
+  try {
+    const url = `${META_GRAPH_API_URL}/${adAccountId}?fields=timezone_name,name,currency`;
+    const res = await fetchMeta(url, accessToken, "ad-account-timezone");
+    const timezoneName = res.timezone_name || "America/New_York";
+    console.log(`Fetched timezone for ${adAccountId}: ${timezoneName}`);
+
+    // Upsert to cache
+    await supabase.from("meta_ad_accounts").upsert({
+      ad_account_id: adAccountId,
+      client_id: clientId,
+      timezone_name: timezoneName,
+      name: res.name || null,
+      currency: res.currency || "USD",
+      last_seen_at: new Date().toISOString(),
+    }, { onConflict: "ad_account_id" });
+
+    return timezoneName;
+  } catch (err) {
+    console.warn(`Failed to fetch timezone for ${adAccountId}, using fallback:`, err);
+    return cached?.timezone_name || "America/New_York";
+  }
+}
