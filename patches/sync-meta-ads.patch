+// ── Timezone-aware date helpers ──
+// Compute "yesterday" in the ad account's timezone, not UTC.
+function getDateInTimezone(tz: string, daysOffset = 0): string {
+  // Use Intl.DateTimeFormat to get the current date in the target timezone
+  const now = new Date();
+  const formatter = new Intl.DateTimeFormat("en-CA", {
+    timeZone: tz,
+    year: "numeric",
+    month: "2-digit",
+    day: "2-digit",
+  });
+  // Parse the formatted date
+  const parts = formatter.formatToParts(now);
+  const y = parts.find(p => p.type === "year")!.value;
+  const m = parts.find(p => p.type === "month")!.value;
+  const d = parts.find(p => p.type === "day")!.value;
+  const localDate = new Date(`${y}-${m}-${d}T12:00:00`); // noon to avoid DST edge
+  localDate.setDate(localDate.getDate() + daysOffset);
+  return localDate.toISOString().split("T")[0];
 }
 
